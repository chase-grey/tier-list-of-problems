# Problem-Polling App Configuration

# Google Apps Script backend URL
# Replace with your actual deployment URL after deploying the script
VITE_API_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID_HERE/exec"

# Set this to 'true' to enable admin dashboard features
VITE_ENABLE_ADMIN="false"

# Polling cycle identifier (e.g., "Feb26", "May26", "Aug26", "Nov26")
# 2026Q1=Feb26, 2026Q2=May26, 2026Q3=Aug26, 2026Q4=Nov26
VITE_POLLING_CYCLE_ID="Aug26"

# Polling stage: "1" for priority ranking (all users), "2" for interest ranking (QM and dev TL only)
# Stage 1: All users rank priorities on all pitches
# Stage 2: Only QM and dev TL roles rank interest on pitches that passed Stage 1
#          Update stage2-qan-ids.json with the QAN IDs that passed Stage 1 before deploying Stage 2
VITE_POLLING_STAGE="1"
